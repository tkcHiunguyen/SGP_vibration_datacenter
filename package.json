{
  "name": "sgp-vibration-datacenter",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "start": "pnpm -C server start",
    "dev": "pnpm -r --parallel --stream --filter ./server --filter ./server/client dev",
    "postinstall": "pnpm db:init",
    "db:init": "pnpm -C server db:init",
    "db:schema:export": "pnpm -C server db:schema:export",
    "build:server": "pnpm -C server build",
    "build:client": "pnpm -C server/client build",
    "build": "pnpm build:client && pnpm build:server && pnpm db:schema:export",
    "typecheck": "pnpm -C server/client typecheck && pnpm -C server typecheck",
    "test": "pnpm -C server test",
    "perf:build": "pnpm -C server/client build && pnpm -C server build",
    "perf:lighthouse:clean": "rm -rf output/perf/lighthouse",
    "perf:lighthouse:mobile": "pnpm perf:build && lhci autorun --config=./server/client/lighthouserc.mobile.json",
    "perf:lighthouse:desktop": "pnpm perf:build && lhci autorun --config=./server/client/lighthouserc.desktop.json",
    "perf:lighthouse": "pnpm perf:lighthouse:clean && pnpm perf:lighthouse:mobile && pnpm perf:lighthouse:desktop && node scripts/perf/lighthouse-summary.mjs",
    "perf:ux-delay": "pnpm perf:build && node scripts/perf/ux-delay-benchmark.mjs --start-server",
    "arch:extract": "node scripts/architecture/extract-architecture.mjs",
    "arch:generate": "node scripts/architecture/generate-architecture.mjs",
    "graphify:update": "python3 scripts/graphify_source_only.py",
    "graphify:watch": "python3 scripts/graphify_source_only.py --watch --interval 2",
    "arch:render": "node scripts/architecture/render-refined-diagrams.mjs",
    "arch:all": "pnpm arch:extract && pnpm arch:generate && pnpm arch:render"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "chrome-launcher": "^1.2.1",
    "dependency-cruiser": "^17.3.10",
    "knip": "^6.7.0",
    "madge": "^8.0.0",
    "puppeteer-core": "^24.42.0",
    "ts-morph": "^28.0.0"
  }
}

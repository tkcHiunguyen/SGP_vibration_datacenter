NODE_ENV=development
PORT=8080
# HOST dùng khi HOSTS không được cấu hình.
HOST=0.0.0.0
# Tùy chọn: bind server vào đúng các IP card mạng, phân tách bằng dấu phẩy.
# Ví dụ Windows: chỉ lắng nghe trên 2 NIC này, không mở 0.0.0.0/localhost.
# HOSTS=192.168.22.3,192.168.23.2
LOG_LEVEL=info
# URL public/LAN để thiết bị ESP tải OTA (nên dùng IP/domain thật, không dùng localhost)
# OTA_PUBLIC_BASE_URL=http://192.168.1.10:8080

# MySQL (khuyến nghị)
MYSQL_URL=mysql://root@127.0.0.1:3306/sgp_vibration_datacenter
# Hoặc tách rời từng biến:
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=
# MYSQL_DATABASE=sgp_vibration_datacenter
# MYSQL_CONNECTION_LIMIT=10
# Mặc định true: nếu MySQL không bật/không tồn tại, server fallback sang in-memory để UI vẫn chạy.
DB_FALLBACK_ON_UNAVAILABLE=true
# Đặt false ở production nếu muốn fail-fast khi MySQL không sẵn sàng.
# DB_FALLBACK_ON_UNAVAILABLE=false

# Tùy chọn cũ (tương thích ngược)
DATABASE_URL=

# Optional: token dùng để xác thực kết nối device socket.io
DEVICE_AUTH_TOKEN=
COMMAND_TIMEOUT_MS=10000
COMMAND_TIMEOUT_SWEEP_MS=1000
TELEMETRY_DEDUPE_WINDOW_MS=60000
TELEMETRY_MAX_PER_DEVICE_PER_MINUTE=600
TELEMETRY_MAX_GLOBAL_PER_MINUTE=50000
TELEMETRY_RETENTION_HOURS=168
SPECTRUM_STORAGE_DIR=storage/spectrum
SPECTRUM_FRAME_FLUSH_MS=700
SPECTRUM_MATCH_WINDOW_MS=500

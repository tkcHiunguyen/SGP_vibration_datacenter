NODE_ENV=development
PORT=8080
HOST=0.0.0.0
LOG_LEVEL=info

# MySQL (khuyến nghị)
MYSQL_URL=mysql://root@127.0.0.1:3306/sgp_vibration_datacenter
# Hoặc tách rời từng biến:
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=
# MYSQL_DATABASE=sgp_vibration_datacenter
# MYSQL_CONNECTION_LIMIT=10

# Tùy chọn cũ (tương thích ngược)
DATABASE_URL=

# Optional: token dùng để xác thực kết nối device socket.io
DEVICE_AUTH_TOKEN=
COMMAND_TIMEOUT_MS=10000
COMMAND_TIMEOUT_SWEEP_MS=1000
TELEMETRY_DEDUPE_WINDOW_MS=60000
TELEMETRY_MAX_PER_DEVICE_PER_MINUTE=600
TELEMETRY_MAX_GLOBAL_PER_MINUTE=50000
TELEMETRY_RETENTION_HOURS=168

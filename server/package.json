{
  "name": "sgp-vibration-datacenter-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec \"tsx src/index.ts\"",
    "dev:web": "pnpm -C ../web dev",
    "build": "tsc -p tsconfig.json",
    "build:web": "pnpm -C ../web build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test $(find src -name '*.test.ts' -print)",
    "start": "nodemon --watch src --ext ts --exec \"tsx src/index.ts\"",
    "start:prod": "node dist/index.js",
    "start:dev": "pnpm run dev",
    "simulate:devices": "tsx src/tools/device-simulator.ts",
    "quality:s8": "tsx src/tools/sprint8-quality-gate.ts",
    "quality:s9": "tsx src/tools/sprint9-rollout-drill.ts",
    "quality:s10": "tsx src/tools/sprint10-phase-exit.ts",
    "migrate:pg-to-mysql": "tsx src/tools/migrate-postgres-to-mysql.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^8.3.0",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.4",
    "ioredis": "^5.10.1",
    "mysql2": "^3.20.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "nodemon": "^3.1.14",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}

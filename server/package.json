{
  "name": "sgp-vibration-datacenter-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec \"tsx src/index.ts\"",
    "build": "tsc -p tsconfig.json",
    "db:init": "tsx src/tools/bootstrap-db-schema.ts",
    "db:schema:export": "tsx src/tools/export-mysql-schema.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test $(find src -name '*.test.ts' -print)",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^8.3.0",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.4",
    "mysql2": "^3.20.0",
    "socket.io": "^4.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "nodemon": "^3.1.14",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
